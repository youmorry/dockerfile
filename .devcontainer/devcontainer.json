{
  "name": "Java 17 + Maven 3.9 (SDKMAN) - developer",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:Asia/Tokyo}",
      "GIT_DELTA_VERSION": "0.19.2",
      "ZSH_IN_DOCKER_VERSION": "1.2.1",
      "HTTP_PROXY": "http://host.docker.internal:8080",
      "HTTPS_PROXY": "http://host.docker.internal:8080",
      "NO_PROXY": "localhost,127.0.0.1",
      "http_proxy": "http://host.docker.internal:8080",
      "https_proxy": "http://host.docker.internal:8080",
      "no_proxy": "localhost,127.0.0.1"
    }
  },
  "features": {
      "ghcr.io/devcontainers/features/java:1": {
        "version": "17.0.18",
        "jdkDistro": "amzn",
        "additionalVersions": "26",
        "installMaven": true,
        "mavenVersion": "3.9.14"
      },
      "ghcr.io/devcontainers/features/node:1": {},
      "ghcr.io/devcontainers/features/docker-in-docker:2": {
        "moby": false
      }
  },
  "remoteUser": "vscode",
  "containerUser": "vscode",
  "customizations": {
    "vscode": {
      "settings": {
        "java.jdt.ls.java.home": "/home/vscode/.sdkman/candidates/java/26-amzn",
        "java.configuration.runtimes": [
          {
            "name": "JavaSE-17",
            "path": "/home/vscode/.sdkman/candidates/java/current",
            "default": true
          }
        ],
        "maven.executable.path": "/home/vscode/.sdkman/candidates/maven/current/bin/mvn"
      }
    }
  },
  "mounts": [
    "source=dockerfile-maven-${devcontainerId},target=/home/vscode/.m2,type=volume",
    "source=dockerfile-commandhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=dockerfile-claude-${devcontainerId},target=/home/vscode/.claude,type=volume"
  ],
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/vscode/.claude",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true"
  }
}
